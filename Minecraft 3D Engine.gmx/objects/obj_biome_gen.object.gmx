        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>//init chunk
//Set up world-gen state once per session. Terrain/biome/decoration are
//all pure functions of position + these seeds, so any chunk can be
//(re)generated on demand with no memory of what came before -- that's
//what makes chunk streaming and effectively-infinite terrain possible.
global.height_seed_x = random(1000);
global.height_seed_y = random(1000);
global.biome_seed_x = random(1000);
global.biome_seed_y = random(1000);
global.deco_seed_x = random(1000);

global.chunk_tiles = 8;   //chunk size, in 32-unit tiles per side

//key: scr_EncodeBlockKey(tile_x, tile_y, layer_h) -> 0 (removed) or an
//object_index (placed/overridden). Only ever holds positions that
//differ from the natural generation, so it stays small.
global.block_edits = ds_map_create();

//key: scr_EncodeChunkKey(chunk_cx, chunk_cy) -> a ds_list of block-key
//positions the player placed outside their tile's natural column (e.g.
//building upward/floating) -- the natural fill loop never visits those
//positions on its own, so they need to be tracked separately to survive
//unload/reload.
global.chunk_extra = ds_map_create();

//key: scr_EncodeChunkKey(chunk_cx, chunk_cy) -> 1 while that chunk
//currently has instances spawned.
global.loaded_chunks = ds_map_create();

last_chunk_cx = floor(obj_camera.x / (global.chunk_tiles * 32));
last_chunk_cy = floor(obj_camera.y / (global.chunk_tiles * 32));

scr_UpdateLoadedChunks();
</string>
          </argument>
        </arguments>
      </action>
    </event>
    <event eventtype="3" enumb="0">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>//Only redo chunk load/unload when the player actually crosses into a
//new chunk, not every single frame.
var current_cx = floor(obj_camera.x / (global.chunk_tiles * 32));
var current_cy = floor(obj_camera.y / (global.chunk_tiles * 32));

if (current_cx != last_chunk_cx || current_cy != last_chunk_cy)
{
    last_chunk_cx = current_cx;
    last_chunk_cy = current_cy;
    scr_UpdateLoadedChunks();
}
</string>
          </argument>
        </arguments>
      </action>
    </event>
  </events>

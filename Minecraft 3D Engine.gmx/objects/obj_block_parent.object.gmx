        <arguments>
          <argument>
            <kind>1</kind>
            <string>// Shared base for every targetable/destroyable block type (grass, sand,
// snow, tinted_cross, and any future block). Never instantiated directly.
// hit_x1/hit_y1 is the near corner of the block's hit box relative to its
// own x/y, so raycasting/collision can test any block type with one
// generic "with (obj_block_parent)" check instead of one per type.
hit_x1 = 0;
hit_y1 = 0;

// Whether the player can stand on/collide with this block at all.
// Decorative blocks (e.g. obj_tinted_cross) override this to false.
is_solid = true;

// Whether this block is fully enclosed by solid neighbors on all 6
// sides, so it can never actually be seen. Not recomputed every frame
// (too slow) -- obj_biome_gen sets it analytically at world-gen time,
// and scr_UpdateBuriedAround keeps it correct when blocks are placed or
// broken during play.
is_buried = false;

// Which chunk this instance belongs to (set by scr_GenerateChunk right
// after creation) -- scr_UnloadChunk uses this to find exactly the
// instances to destroy when a chunk goes out of range.
chunk_cx = 0;
chunk_cy = 0;

// Ramps from 0 to 1 after spawning (see the Step event) so newly
// generated/streamed-in blocks fade in instead of popping into view.
fade_alpha = 0;
</string>
          </argument>
        </arguments>
      </action>
    </event>
    <event eventtype="3" enumb="0">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>// Cheap per-frame visibility check: distance + a generous view-cone
// (frustum) test against the camera's actual 3D look vector (lookx/
// looky/lookz -- the same one raycasting uses), so blocks well outside
// where the camera is pointing skip drawing entirely. This has to be a
// true 3D cone, not just a horizontal angle check against facingDir --
// a horizontal-only check stays a narrow wedge even when looking
// straight down, wrongly culling everything not directly in that
// horizontal direction even though looking down actually reveals a wide
// disc all around the player. is_buried is NOT recomputed here -- see
// the Create event comment.
//
// Written entirely in squared distances -- no sqrt, no division -- since
// this runs for every loaded block every frame (there can be thousands).
// obj_camera's look vector is a true unit vector (see its Step event),
// so cos(angle) = dot(to_block, look) / |to_block| needs no second
// normalization. To compare against a threshold angle without a sqrt,
// square both sides -- but that only works for acute (under 90 degree)
// thresholds; our 100-degree half-angle threshold is obtuse (negative
// cosine), so a negative dot (angle > 90) has to be let through before
// the squared comparison, since squaring would otherwise throw away the
// sign that distinguishes "just past 90" from "far past 90".
//
// Sets the engine's own built-in "visible" instead of a custom flag, so
// GameMaker skips calling Draw entirely for culled instances rather than
// calling it to do nothing.
if (is_buried)
{
    // A buried block can never be seen, so there's nothing to fade in --
    // skip the distance/frustum math below entirely and jump straight to
    // fade_alpha = 1, instead of ramping it 0.05/frame for however long
    // the block stays buried. It'll go right back to normal if
    // scr_UpdateBuriedAround ever un-buries it later.
    visible = false;
    fade_alpha = 1;
    exit;
}
else
{
    var to_x = x - obj_camera.x;
    var to_y = y - obj_camera.y;
    var to_z = z - obj_camera.z;
    var dist_sq = to_x * to_x + to_y * to_y + to_z * to_z;
    var render_dist = global.renderDistance;

    if (dist_sq &gt;= render_dist * render_dist)
    {
        visible = false;
    }
    else if (dist_sq &lt; 1)
    {
        visible = true;   //essentially on top of the camera
    }
    else
    {
        var dot = to_x * obj_camera.lookx + to_y * obj_camera.looky + to_z * obj_camera.lookz;

        if (dot &gt;= 0)
        {
            visible = true;
        }
        else
        {
            visible = (dot * dot &lt; 0.030138 * dist_sq);   //0.1736^2, i.e. the 100-degree half-angle cone
        }
    }
}

// Fade in newly spawned/streamed-in blocks instead of popping.
if (fade_alpha &lt; 1)
{
    fade_alpha += 0.05;
    if (fade_alpha &gt; 1)
    {
        fade_alpha = 1;
    }
}
</string>
          </argument>
        </arguments>
      </action>

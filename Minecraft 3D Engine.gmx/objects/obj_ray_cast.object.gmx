        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>//Choose block to create based on the selected hotbar slot
//(global.slots, already set by number keys 1/2/3 in obj_hud).
var block_type = obj_grass_block;

switch (global.slots)
{
    case 0:
        block_type = obj_grass_block;
        break;
    case 1:
        block_type = obj_sand_block;
        break;
    case 2:
        block_type = obj_snow_block;
        break;
}

if (mouse_check_button_released(mb_right))
{
    var block = instance_create(x, y, block_type);
    block.z = z + z_offset;
}


</string>
          </argument>
        </arguments>
      </action>
    </event>
    <event eventtype="6" enumb="56">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>// Destroy exactly what the raycast hit (scr_Raycast.gml set target_block
// when this reticle was spawned), instead of re-searching by distance.
if (instance_exists(target_block))
{
    with (target_block)
    {
        instance_destroy();
    }
}

</string>
          </argument>
        </arguments>
      </action>
    </event>
    <event eventtype="8" enumb="73">
      <action>
        <libid>1</libid>
